# ──────────────────────────────────────────────────────────────
# Variáveis de ambiente para a Fatura XP
# Copie este arquivo para .env.local e preencha os valores
# ──────────────────────────────────────────────────────────────

# Senha do PDF (primeiros 5 dígitos do CPF)
# NUNCA commite este arquivo com valor preenchido!
PDF_PASSWORD=

# Chave secreta para proteger o endpoint /api/process-invoice
# Gere com: openssl rand -hex 32
API_SECRET=

# GitHub – para commitar o invoices.json atualizado (triggering Vercel redeploy)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=fatura-xp
GITHUB_BRANCH=main
